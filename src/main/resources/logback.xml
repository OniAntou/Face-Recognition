<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Suppress noisy OpenCV/JavaFX framework logs -->
    <logger name="org.opencv" level="WARN" />
    <logger name="javafx" level="WARN" />
    <logger name="atlantafx" level="WARN" />

    <!-- Application logs at INFO level for production -->
    <logger name="com.example.facedetection" level="INFO" />

    <root level="WARN">
        <appender-ref ref="STDOUT" />
    </root>
</configuration>
