<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="720.0" prefWidth="1120.0"
            style="-fx-background-color: #0F0F23;"
            stylesheets="@styles.css"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.facedetection.controller.ViewController">

    <top>
        <VBox spacing="12" id="headerBar">
            <HBox alignment="CENTER_LEFT" spacing="16">
                <VBox alignment="CENTER_LEFT">
                    <Label id="appTitle" text="Face Recognition" />
                    <Label id="appSubtitle" text="Real-time Detection and Analysis" />
                </VBox>

                <Region HBox.hgrow="ALWAYS" />

                <ComboBox fx:id="cameraSelector" prefHeight="38.0" prefWidth="180.0"
                          promptText="Select Camera" styleClass="combo-box" />
                <Button fx:id="cameraButton" onAction="#toggleCamera"
                        prefHeight="38.0" prefWidth="150.0"
                        text="Start Camera"
                        styleClass="btn-primary" />
                <Button fx:id="insertImageButton" onAction="#selectImage"
                        prefHeight="38.0" prefWidth="150.0"
                        text="Upload Image"
                        styleClass="btn-secondary" />
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="18">
                <CheckBox fx:id="adaptiveExposureCheckBox"
                          onAction="#handleAdaptiveExposureToggle"
                          selected="true"
                          styleClass="toggle-chip"
                          text="Adaptive Exposure" />
                <CheckBox fx:id="brightLightModeCheckBox"
                          onAction="#handleBrightLightModeToggle"
                          selected="true"
                          styleClass="toggle-chip"
                          text="Bright-Light Mode" />
            </HBox>
        </VBox>
    </top>

    <center>
        <HBox id="contentArea" spacing="24" alignment="CENTER">
            <padding>
                <Insets bottom="28.0" left="28.0" right="28.0" top="28.0" />
            </padding>

            <VBox fx:id="sourceCard" HBox.hgrow="ALWAYS" alignment="TOP_CENTER"
                  spacing="12" styleClass="view-card">
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Region styleClass="status-dot" />
                    <Label text="Source" styleClass="card-header" />
                </HBox>
                <Separator styleClass="card-separator" />
                <StackPane fx:id="sourceViewport" VBox.vgrow="ALWAYS" styleClass="image-viewport">
                    <ImageView fx:id="originalImageView"
                               pickOnBounds="true" preserveRatio="true" smooth="true" />
                </StackPane>
                <padding>
                    <Insets bottom="18.0" left="18.0" right="18.0" top="14.0" />
                </padding>
            </VBox>

            <VBox HBox.hgrow="ALWAYS" alignment="TOP_CENTER"
                  spacing="12" styleClass="view-card">
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Region styleClass="status-dot" />
                    <Label text="Result" styleClass="card-header" />
                </HBox>
                <Separator styleClass="card-separator" />
                <StackPane fx:id="resultViewport" VBox.vgrow="ALWAYS" styleClass="image-viewport">
                    <ImageView fx:id="processedImageView"
                               pickOnBounds="true" preserveRatio="true" smooth="true" />
                </StackPane>
                <padding>
                    <Insets bottom="18.0" left="18.0" right="18.0" top="14.0" />
                </padding>
            </VBox>
        </HBox>
    </center>

    <bottom>
        <HBox id="footerBar" alignment="CENTER_LEFT" spacing="16">
            <Label fx:id="statusLabel" id="statusLabel" text="Ready" />
            <Label fx:id="fpsLabel" styleClass="meta-label" text="FPS: --" />
            <Label fx:id="exposureStatusLabel" styleClass="meta-label" text="Exposure: Ready" />
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="engineLabel" id="engineLabel" text="Engine: Idle" />
        </HBox>
    </bottom>

</BorderPane>
