<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="800.0" prefWidth="1280.0"
            stylesheets="@styles.css"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.facedetection.controller.ViewController">

    <left>
        <VBox spacing="20" styleClass="sidebar">
            <Label text="CONTROL PANEL" styleClass="sidebar-section-title" />
            
            <VBox spacing="12">
                <Label text="Primary Source" styleClass="stat-label" />
                <ComboBox fx:id="cameraSelector" maxWidth="Infinity"
                          promptText="Select Device" styleClass="combo-box" />
                <Button fx:id="cameraButton" onAction="#toggleCamera"
                        maxWidth="Infinity" text="Start Camera"
                        styleClass="btn-primary" />
                <Button fx:id="insertImageButton" onAction="#selectImage"
                        maxWidth="Infinity" text="Upload Image"
                        styleClass="btn-secondary" />
            </VBox>

            <Separator styleClass="card-separator" />

            <Label text="AI PIPELINE SETTINGS" styleClass="sidebar-section-title" />
            <VBox spacing="14">
                <CheckBox fx:id="adaptiveExposureCheckBox"
                          onAction="#handleAdaptiveExposureToggle"
                          selected="true"
                          styleClass="toggle-chip"
                          text="Adaptive Exposure" />
                <CheckBox fx:id="brightLightModeCheckBox"
                          onAction="#handleBrightLightModeToggle"
                          selected="true"
                          styleClass="toggle-chip"
                          text="Bright-Light Mode" />
                <CheckBox fx:id="genderRecognitionCheckBox"
                          onAction="#handleGenderRecognitionToggle"
                          selected="false"
                          styleClass="toggle-chip"
                          text="Gender Recognition" />
            </VBox>

            <Region VBox.vgrow="ALWAYS" />

            <VBox spacing="10" styleClass="stat-card">
                <Label text="SYSTEM STATUS" styleClass="stat-label" />
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Region styleClass="status-dot-active" />
                    <Label fx:id="engineLabel" text="Engine: Idle" styleClass="stat-value" />
                </HBox>
            </VBox>
        </VBox>
    </left>

    <top>
        <HBox id="headerBar" alignment="CENTER_LEFT" spacing="24">
            <VBox alignment="CENTER_LEFT">
                <Label id="appTitle" text="Face Recognition Pro" />
                <Label id="appSubtitle" text="Advanced AI Vision &amp; Real-time Analysis" />
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <HBox spacing="12" alignment="CENTER_RIGHT">
                <VBox alignment="CENTER_RIGHT" spacing="2">
                    <Label fx:id="fpsLabel" styleClass="stat-value" text="-- FPS" />
                    <Label text="PERFORMANCE" styleClass="stat-label" />
                </VBox>
            </HBox>
        </HBox>
    </top>

    <center>
        <HBox id="contentArea" spacing="28" alignment="CENTER">
            <padding>
                <Insets bottom="32.0" left="32.0" right="32.0" top="32.0" />
            </padding>

            <!-- Source Card -->
            <VBox fx:id="sourceCard" HBox.hgrow="ALWAYS" alignment="TOP_CENTER"
                  spacing="16" styleClass="view-card">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="SOURCE INPUT" styleClass="card-header" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label text="LIVE" styleClass="stat-label" style="-fx-text-fill: -color-accent-success;" />
                </HBox>
                <StackPane fx:id="sourceViewport" VBox.vgrow="ALWAYS" styleClass="image-viewport">
                    <ImageView fx:id="originalImageView"
                               pickOnBounds="true" preserveRatio="true" smooth="true" />
                </StackPane>
                <padding>
                    <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                </padding>
            </VBox>

            <!-- Result Card -->
            <VBox HBox.hgrow="ALWAYS" alignment="TOP_CENTER"
                  spacing="16" styleClass="view-card">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="AI ANALYSIS RESULT" styleClass="card-header" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label fx:id="exposureStatusLabel" text="EXPOSURE: OK" styleClass="stat-label" />
                </HBox>
                <StackPane fx:id="resultViewport" VBox.vgrow="ALWAYS" styleClass="image-viewport">
                    <ImageView fx:id="processedImageView"
                               pickOnBounds="true" preserveRatio="true" smooth="true" />
                </StackPane>
                <padding>
                    <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                </padding>
            </VBox>
        </HBox>
    </center>

    <bottom>
        <HBox id="footerBar" alignment="CENTER_LEFT" spacing="20">
            <Region styleClass="status-dot-active" />
            <Label fx:id="statusLabel" id="statusLabel" text="System Ready" />
            <Region HBox.hgrow="ALWAYS" />
            <Label text="v1.2.0-PRO" styleClass="meta-label" />
        </HBox>
    </bottom>

</BorderPane>
